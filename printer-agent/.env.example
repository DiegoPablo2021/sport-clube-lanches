SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# console, file ou windows
PRINT_MODE=file

# Intervalo de consulta em milissegundos.
POLL_INTERVAL_MS=5000

# Usado no modo windows. Deixe vazio para usar a impressora padrao.
WINDOWS_PRINTER_NAME=

# Largura aproximada do papel. Impressoras 58mm costumam ficar bem com 32 colunas.
PAPER_COLUMNS=32
